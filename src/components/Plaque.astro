---
/*
  Plaque superior fija (.lb.top), z-index 80.
  Izquierda: "K. Herazo · Portafolio". Derecha: "Kevin Herazo — 2026" + boton tema.
  STUB Fase 0 — estilos y boton funcional en Fase 1 del ROADMAP.
*/
---

<header class="lb top" data-plaque>
  <span class="lb-left">K. Herazo · <strong>Portafolio</strong></span>
  <span class="lb-right">
    Kevin Herazo — 2026
    <button id="themeToggle" type="button" aria-label="Cambiar tema">
      <svg class="ic" aria-hidden="true"><use href="#ic-moon" /></svg>
    </button>
  </span>
</header>

