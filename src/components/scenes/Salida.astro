---
/*
  Escena 5 — Salida / libro de visitas. Centrada: etiqueta, frase serif italic y
  enlaces mono con icono (el primero, .solid, relleno ink). Copy exacto del PRD 6.
*/
---

<section class="scene fin" data-slate="Salida" data-screen-label="Salida">
  <div class="wrap">
    <p class="end">Salida · libro de visitas</p>
    <p class="q">Hagamos el próximo.</p>
    <nav class="links" aria-label="Contacto">
      <a class="solid" href="mailto:kevinaxelhr18@gmail.com">
        <svg class="ic" aria-hidden="true"><use href="#ic-mail" /></svg>
        kevinaxelhr18@gmail.com
      </a>
      <a href="tel:+573001908759">
        <svg class="ic" aria-hidden="true"><use href="#ic-phone" /></svg>
        +57 3001908759
      </a>
      <a href="https://github.com/KawKuroi" target="_blank" rel="noopener">
        <svg class="ic" aria-hidden="true"><use href="#ic-github" /></svg>
        github.com/KawKuroi
      </a>
      <a href="/assets/CV-Kevin-Herazo.pdf" target="_blank" rel="noopener">
        <svg class="ic" aria-hidden="true"><use href="#ic-doc" /></svg>
        CV
      </a>
    </nav>
  </div>
</section>

<style>
  .fin .wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(18px, 4vh, 34px);
    text-align: center;
  }

  .end {
    margin: 0;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .26em;
    text-transform: uppercase;
    color: var(--teal);
  }

  .q {
    margin: 0;
    font-style: italic;
    font-size: clamp(40px, 8vw, 86px);
    line-height: 1.04;
    color: var(--ink);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 11px 18px;
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: .04em;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: border-color .25s var(--ease), color .25s var(--ease),
      background .25s var(--ease);
  }

  .links a .ic {
    font-size: 17px;
  }

  .links a:hover {
    border-color: var(--teal);
    color: var(--teal);
  }

  .links a.solid {
    color: var(--paper);
    background: var(--ink);
    border-color: var(--ink);
  }

  .links a.solid:hover {
    color: var(--paper);
    background: var(--teal);
    border-color: var(--teal);
  }

  .links a:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 3px;
  }
</style>
