---
/*
  Escena 5 — Salida / libro de visitas. Centrada: etiqueta, frase serif italic y enlaces mono
  con icono (el primero, .solid, relleno ink). Copy y estilado 1:1 con el diseno original.
*/
---

<section class="scene fin" data-slate="Salida" data-screen-label="Salida">
  <div class="wrap">
    <div class="q">Hagamos el próximo.</div>
    <nav class="links" aria-label="Contacto">
      <a class="solid" href="mailto:kevinaxelhr18@gmail.com">
        <svg class="ic" aria-hidden="true"><use href="#ic-mail" /></svg>
        kevinaxelhr18@gmail.com
      </a>
      <a href="tel:+573001908759">
        <svg class="ic" aria-hidden="true"><use href="#ic-phone" /></svg>
        +57 3001908759
      </a>
      <a href="https://github.com/KawKuroi" target="_blank" rel="noopener">
        <svg class="ic" aria-hidden="true"><use href="#ic-github" /></svg>
        github.com/KawKuroi
      </a>
      <a
        href="https://www.linkedin.com/in/kevin-axel-herazo-rol%C3%B3n-15a517266/"
        target="_blank"
        rel="noopener"
      >
        <svg class="ic" aria-hidden="true"><use href="#ic-linkedin" /></svg>
        LinkedIn
      </a>
      <a href="/assets/CV-Kevin-Herazo.pdf" target="_blank" rel="noopener">
        <svg class="ic" aria-hidden="true"><use href="#ic-doc" /></svg>
        CV
      </a>
    </nav>
  </div>
</section>

<style>
  .fin {
    text-align: center;
    align-items: center;
  }

  .end {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 26px;
  }

  .q {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(34px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -.01em;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 11px;
    justify-content: center;
    margin-top: 38px;
  }

  .links a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .04em;
    border: 1px solid var(--line);
    padding: 13px 19px;
    transition: all .25s;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--ink);
  }

  .links a .ic {
    width: 15px;
    height: 15px;
  }

  .links a:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .links a.solid {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .links a.solid:hover {
    background: var(--teal);
    border-color: var(--teal);
  }

  .links a:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 3px;
  }
</style>
