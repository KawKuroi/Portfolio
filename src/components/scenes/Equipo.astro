---
/*
  Escena 3 — II · El equipo y los creditos. Grid 2 columnas (Stack | Formacion), colapsa a
  1 col en <=760px. Copy y estilado 1:1 con el diseno original (PRD 6 / Escena 3).
*/
---

<section class="scene" data-slate="El equipo" data-screen-label="El equipo">
  <div class="wrap">
    <div class="sh">
      <span class="act">II</span>
      <h2>El <em>equipo</em> y los <em>créditos</em></h2>
      <span class="ln"></span>
      <span class="ct">stack · formación</span>
    </div>

    <div class="two">
      <div>
        <div class="eh">Stack</div>
        <dl class="stack">
          <div class="grp">
            <dt><svg class="ic" aria-hidden="true"><use href="#ic-code" /></svg>Lenguajes</dt>
            <dd>Python · Java · SQL · MongoDB</dd>
          </div>
          <div class="grp">
            <dt><svg class="ic" aria-hidden="true"><use href="#ic-server" /></svg>Backend</dt>
            <dd>Spring Boot · Django · DRF · FastAPI</dd>
          </div>
          <div class="grp">
            <dt><svg class="ic" aria-hidden="true"><use href="#ic-spark" /></svg>IA</dt>
            <dd>LangChain · Hugging Face · LLMs</dd>
          </div>
          <div class="grp">
            <dt><svg class="ic" aria-hidden="true"><use href="#ic-chart" /></svg>Datos / ML</dt>
            <dd>TensorFlow · Pandas · NumPy · Power BI</dd>
          </div>
          <div class="grp">
            <dt><svg class="ic" aria-hidden="true"><use href="#ic-cloud" /></svg>Cloud</dt>
            <dd>Google Cloud · Apigee · Docker · Git</dd>
          </div>
        </dl>
      </div>

      <div>
        <div class="eh">Formación</div>
        <div class="formacion">
          <div class="ei">
            <div class="t">U. Jorge Tadeo Lozano</div>
            <div class="s"><span>Ingeniería de Sistemas</span><span>2022 — Actual</span></div>
          </div>
          <div class="ei">
            <div class="t">Data Analytics</div>
            <div class="s"><span>Google · Coursera</span><span>En curso</span></div>
          </div>
          <div class="ei">
            <div class="t">API Design &amp; Fundamentals</div>
            <div class="s"><span>Google Cloud · Apigee</span><span>✓</span></div>
          </div>
          <div class="ei">
            <div class="t">API Development</div>
            <div class="s"><span>Google Cloud · Apigee</span><span>✓</span></div>
          </div>
          <div class="ei">
            <div class="t">API Security · OAuth / JWT</div>
            <div class="s"><span>Google Cloud · Apigee</span><span>✓</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(30px, 5vw, 72px);
  }

  .eh {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 6px;
  }

  .stack {
    margin: 0;
  }

  .grp {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 14px;
    padding: 10px 0;
    border-top: 1px solid var(--line2);
    align-items: baseline;
  }

  .grp:first-of-type {
    border-top: none;
  }

  .grp dt {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--soft);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .grp dt .ic {
    width: 14px;
    height: 14px;
    color: var(--teal);
    stroke-width: 1.5;
  }

  .grp dd {
    margin: 0;
    font-size: 14.5px;
    color: var(--ink);
  }

  .ei {
    padding: 9px 0;
    border-top: 1px solid var(--line2);
  }

  .ei:first-of-type {
    border-top: none;
  }

  .ei .t {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 18px;
  }

  .ei .s {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--soft);
    margin-top: 4px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  @media (max-width: 760px) {
    .two {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
</style>
