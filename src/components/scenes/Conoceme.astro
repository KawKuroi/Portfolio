---
/*
  Escena 4 — III · Conoceme. Persiana (acordeon) con 20 piezas favoritas. La persiana llena
  el alto disponible de la escena (estirada), igual que el diseno original (PRD 8).
*/
import Persiana from '../Persiana.astro';
---

<section class="scene act-persiana" data-slate="Conóceme" data-screen-label="Conóceme">
  <div class="wrap">
    <div class="sh">
      <span class="act">III</span>
      <h2><em>Conóceme</em></h2>
      <span class="ln"></span>
      <span class="ct">20 piezas · cine · juegos · libros · música</span>
    </div>
    <Persiana />
    <p class="note">
      // aquí están las piezas que me formaron el gusto —composición, ritmo y color.
      Pasá el cursor sobre una franja para abrirla.
    </p>
  </div>
</section>

<style>
  /* La escena estira su contenido; la persiana ocupa el alto disponible. */
  .scene.act-persiana {
    justify-content: stretch;
  }

  .act-persiana .wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    gap: clamp(12px, 2.2vh, 22px);
  }

  .act-persiana .sh {
    margin-bottom: 0;
    flex: 0 0 auto;
  }

  .note {
    flex: 0 0 auto;
    margin: 0;
    max-width: 80ch;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .06em;
    line-height: 1.6;
    color: var(--soft);
  }

  @media (max-width: 820px) {
    .act-persiana .wrap {
      display: block;
    }

    .act-persiana .sh {
      margin-bottom: 18px;
    }
  }
</style>
