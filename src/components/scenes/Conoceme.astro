---
/*
  Escena 4 — III · Conoceme. Persiana (acordeon) con 20 piezas favoritas.
  STUB Fase 0 — la persiana funcional se construye en Fase 4 del ROADMAP.
*/
import Persiana from '../Persiana.astro';
---

<section class="scene act-persiana" data-slate="Conóceme" data-screen-label="Conóceme">
  <div class="wrap">
    <header class="sh">
      <span class="acto">III</span>
      <h2><em>Conóceme</em></h2>
      <span class="conteo">20 piezas · cine · juegos · libros · música</span>
    </header>
    <Persiana />
    <p class="note">
      // la última sala de la muestra: aquí están las piezas que me formaron el gusto
      —composición, ritmo y color. Pasá el cursor sobre una franja para abrirla.
    </p>
  </div>
</section>

<style>
  /* La escena crece con la persiana (evita recortar bajo el plaque). */
  .scene.act-persiana {
    height: auto;
    min-height: 100vh;
    justify-content: flex-start;
  }

  .note {
    max-width: 70ch;
    margin: clamp(18px, 4vh, 32px) 0 0;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .03em;
    line-height: 1.6;
    color: var(--faint);
  }
</style>
