---
/*
  Escena 2 — I · El trabajo. Disposicion fija: Galeria (la unica). Render en build desde
  PROYECTOS; un script minimo cambia la obra activa y la placa. Estilado 1:1 con el diseno
  original (PRD 7.2). Datos en src/data/proyectos.ts. Copy bilingue por idioma vigente.
*/
import { PROYECTOS } from '../../data/proyectos';
import { obtenerIdioma, obtenerTextos } from '../../i18n/ui';

const idioma = obtenerIdioma(Astro.currentLocale);
const t = obtenerTextos(idioma);
const inicial = PROYECTOS[0];
const numero = (i: number): string => String(i + 1).padStart(2, '0');
---

<section class="scene scene-trabajo" data-slate={t.slates.trabajo} data-screen-label={t.slates.trabajo}>
  <div class="wrap">
    <div class="sh">
      <span class="act">I</span>
      <h2 set:html={t.trabajo.tituloHtml}></h2>
      <span class="ln"></span>
      <span class="ct">{PROYECTOS.length} {t.trabajo.proyectos}</span>
    </div>

    <div id="twGaleria" class="tw-galeria">
      <div class="twg-list">
        {
          PROYECTOS.map((proyecto, i) => (
            <button
              class:list={['twg-item', { on: i === 0 }]}
              type="button"
              data-i={i}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="twg-num">{numero(i)}</span>
              <span class="twg-tx">
                <span class="twg-tt">{proyecto.titulo[idioma]}</span>
                <span class="twg-tg">{proyecto.tags[idioma]}</span>
              </span>
              <span class="twg-yr">{proyecto.anio[idioma]}</span>
            </button>
          ))
        }
        <div class="twg-hint">{t.trabajo.pista}</div>
      </div>

      <div class="twg-stage">
        <div class="twg-frame">
          {
            PROYECTOS.map((proyecto, i) => (
              <figure class:list={['ph', { on: i === 0 }]} data-i={i}>
                <img
                  src={proyecto.img}
                  alt={`${t.trabajo.capturaAlt}${proyecto.titulo[idioma]}`}
                  loading="lazy"
                  onerror="this.closest('.ph').classList.add('empty')"
                />
              </figure>
            ))
          }
        </div>

        <div class="twg-plate" aria-live="polite">
          <div class="pt" data-plate-titulo>{inicial.titulo[idioma]}</div>
          <p class="pd" data-plate-desc>{inicial.descripcion[idioma]}</p>
          <div class="pm">
            <span data-plate-anio>{inicial.anio[idioma]}</span>
            <span class="st" data-plate-estado>{inicial.estado[idioma]}</span>
            <a
              class="go demo"
              data-plate-demo
              href={inicial.demo}
              target="_blank"
              rel="noopener"
              hidden={!inicial.demo}
              ><span class="dot" aria-hidden="true"></span>{t.trabajo.verEnLinea}</a
            >
            <a class="go" data-plate-repo href={inicial.repo} target="_blank" rel="noopener">{t.trabajo.repo}</a>
          </div>
        </div>
      </div>
    </div>

    {/* Acordeon indice (movil/tablet <=1024px): reemplaza la galeria maestro-detalle.
        DOM dual: la galeria de escritorio queda intacta; esto se muestra solo en <=1024px. */}
    <div class="tw-acc">
      {
        PROYECTOS.map((proyecto, i) => (
          <div class:list={['twa-item', { open: i === 0 }]}>
            <button
              class="twa-head"
              type="button"
              aria-expanded={i === 0 ? 'true' : 'false'}
              aria-controls={`twa-panel-${i}`}
            >
              <span class="twa-no">{numero(i)}</span>
              <span class="twa-tx">
                <span class="twa-tt">{proyecto.titulo[idioma]}</span>
                <span class="twa-tg">{proyecto.tags[idioma]}</span>
              </span>
              <span class="twa-yr">{proyecto.anio[idioma]}</span>
              <svg class="ic twa-chev" aria-hidden="true"><use href="#ic-chevron" /></svg>
            </button>
            <div class="twa-panel" id={`twa-panel-${i}`}>
              <div class="twa-inner">
                <figure class="twa-frame">
                  <img
                    src={proyecto.img}
                    alt={`${t.trabajo.capturaAlt}${proyecto.titulo[idioma]}`}
                    loading="lazy"
                    onerror="this.closest('.twa-frame').classList.add('empty')"
                  />
                </figure>
                <div class="twa-txt">
                  <p class="twa-desc">{proyecto.descripcion[idioma]}</p>
                  <div class="twa-meta">
                    <span class="st">{proyecto.estado[idioma]}</span>
                    {proyecto.demo && (
                      <a class="go demo" href={proyecto.demo} target="_blank" rel="noopener">
                        <span class="dot" aria-hidden="true" />{t.trabajo.verEnLinea}
                      </a>
                    )}
                    <a class="go" href={proyecto.repo} target="_blank" rel="noopener">{t.trabajo.repoFlecha}</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { PROYECTOS } from '../../data/proyectos';
  import { obtenerIdioma } from '../../i18n/ui';

  // Idioma vigente (lo fija <html lang> en build) para volcar la placa en el idioma correcto.
  const idioma = obtenerIdioma(document.documentElement.lang);

  const galeria = document.getElementById('twGaleria');
  if (galeria) {
    const items = Array.from(galeria.querySelectorAll<HTMLButtonElement>('.twg-item'));
    const slides = Array.from(galeria.querySelectorAll<HTMLElement>('.ph'));
    const plate = galeria.querySelector<HTMLElement>('.twg-plate');
    const titulo = galeria.querySelector('[data-plate-titulo]');
    const desc = galeria.querySelector('[data-plate-desc]');
    const anio = galeria.querySelector('[data-plate-anio]');
    const estado = galeria.querySelector('[data-plate-estado]');
    const repo = galeria.querySelector<HTMLAnchorElement>('[data-plate-repo]');
    const demo = galeria.querySelector<HTMLAnchorElement>('[data-plate-demo]');

    // Seleccion fija por clic: marca el boton/obra activos y vuelca la placa.
    const seleccionar = (i: number): void => {
      const proyecto = PROYECTOS[i];
      if (!proyecto) return;
      items.forEach((boton, j) => {
        const activo = j === i;
        boton.classList.toggle('on', activo);
        boton.setAttribute('aria-pressed', String(activo));
      });
      slides.forEach((slide, j) => slide.classList.toggle('on', j === i));
      if (titulo) titulo.textContent = proyecto.titulo[idioma];
      if (desc) desc.textContent = proyecto.descripcion[idioma];
      if (anio) anio.textContent = proyecto.anio[idioma];
      if (estado) estado.textContent = proyecto.estado[idioma];
      if (repo) repo.href = proyecto.repo;
      // Enlace al demo con indicador "en línea": solo si el proyecto está publicado.
      if (demo) {
        if (proyecto.demo) {
          demo.href = proyecto.demo;
          demo.hidden = false;
        } else {
          demo.removeAttribute('href');
          demo.hidden = true;
        }
      }
      // Replay de la animacion de entrada de la placa.
      if (plate) {
        plate.classList.remove('fade');
        void plate.offsetWidth;
        plate.classList.add('fade');
      }
    };

    items.forEach((boton, i) => boton.addEventListener('click', () => seleccionar(i)));
  }
</script>

<script>
  // Acordeon indice de El trabajo (movil/tablet <=1024px). Comportamiento de un solo panel
  // abierto a la vez: al abrir uno, los demas se colapsan; pulsar el abierto lo cierra
  // (en todo momento hay como mucho un proyecto abierto, o ninguno). El primero arranca
  // abierto desde el render.
  const itemsTrabajo = Array.from(document.querySelectorAll<HTMLElement>('.tw-acc .twa-item'));
  itemsTrabajo.forEach((item) => {
    const cabecera = item.querySelector<HTMLButtonElement>('.twa-head');
    cabecera?.addEventListener('click', () => {
      const yaAbierto = item.classList.contains('open');
      itemsTrabajo.forEach((otro) => {
        const abrir = otro === item && !yaAbierto;
        otro.classList.toggle('open', abrir);
        otro.querySelector('.twa-head')?.setAttribute('aria-expanded', String(abrir));
      });
    });
  });
</script>

<style>
  /* La escena crece con su contenido (PRD 7.2). */
  .scene.scene-trabajo {
    height: auto;
    min-height: 100vh;
  }

  .tw-galeria {
    display: grid;
    grid-template-columns: minmax(0, .82fr) minmax(0, 1.18fr);
    gap: clamp(26px, 4vw, 58px);
    align-items: center;
  }

  .twg-list {
    display: flex;
    flex-direction: column;
  }

  .twg-item {
    position: relative;
    appearance: none;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    width: 100%;
    color: inherit;
    font-family: inherit;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(12px, 1.6vw, 20px);
    align-items: center;
    padding: clamp(12px, 1.9vh, 19px) 0;
    border-top: 1px solid var(--line2);
    transition: padding-left .35s var(--ease);
  }

  .twg-item:first-child {
    border-top: none;
  }

  .twg-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 3px;
    height: 58%;
    border-radius: 2px;
    background: var(--teal);
    transform: translate(-2px, -50%) scaleY(0);
    transform-origin: center;
    transition: transform .38s var(--ease);
  }

  .twg-item.on::before {
    transform: translate(-2px, -50%) scaleY(1);
  }

  .twg-item:hover {
    padding-left: 8px;
  }

  .twg-item.on {
    padding-left: 18px;
  }

  .twg-num {
    font-family: var(--serif);
    font-size: clamp(20px, 2.5vw, 32px);
    color: var(--faint);
    line-height: 1;
    transition: color .3s;
  }

  .twg-item:hover .twg-num {
    color: var(--soft);
  }

  .twg-item.on .twg-num {
    color: var(--teal);
  }

  .twg-tx {
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
  }

  .twg-tt {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(16px, 1.95vw, 24px);
    line-height: 1.08;
    letter-spacing: -.01em;
    color: var(--soft);
    transition: color .3s;
  }

  .twg-item:hover .twg-tt,
  .twg-item.on .twg-tt {
    color: var(--ink);
  }

  .twg-tg {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: .02em;
    color: var(--faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color .3s;
  }

  .twg-item.on .twg-tg {
    color: var(--soft);
  }

  .twg-yr {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--faint);
    white-space: nowrap;
    align-self: center;
    transition: color .3s;
  }

  .twg-item.on .twg-yr {
    color: var(--teal);
  }

  .twg-hint {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: .05em;
    color: var(--faint);
    margin-top: 14px;
    padding-top: 13px;
    border-top: 1px solid var(--line2);
  }

  .twg-stage {
    min-width: 0;
  }

  .twg-frame {
    position: relative;
    aspect-ratio: 3 / 2;
    border: 1px solid var(--marco);
    background: var(--wall);
    overflow: hidden;
    box-shadow: 0 20px 48px rgba(0, 0, 0, .14);
  }

  .twg-frame .ph {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: scale(1.05);
    transition: opacity .55s var(--ease), transform 1.2s var(--ease);
  }

  .twg-frame .ph.on {
    opacity: 1;
    transform: scale(1);
  }

  .twg-frame .ph img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .twg-frame .ph.empty {
    background: repeating-linear-gradient(
      135deg,
      transparent 0 9px,
      color-mix(in srgb, var(--ink) 5%, transparent) 9px 10px
    );
  }

  .twg-frame .ph.empty img {
    display: none;
  }

  .twg-plate {
    margin-top: clamp(13px, 2vh, 20px);
  }

  .twg-plate .pt {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(19px, 2.3vw, 28px);
    line-height: 1.05;
  }

  .twg-plate .pd {
    font-size: 14px;
    color: var(--soft);
    line-height: 1.58;
    margin-top: 9px;
    max-width: 58ch;
    text-wrap: pretty;
  }

  .twg-plate .pm {
    display: flex;
    align-items: baseline;
    gap: clamp(14px, 2vw, 22px);
    margin-top: 13px;
  }

  .twg-plate .pm span {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--faint);
    letter-spacing: .04em;
  }

  .twg-plate .pm .st {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(15px, 1.7vw, 20px);
    color: var(--ink);
  }

  .twg-plate .pm .go {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--teal);
    border-bottom: 1px solid var(--teal);
    padding-bottom: 2px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: opacity .2s;
  }

  /* "Ver en línea" solo en proyectos con demo: el JS marca [hidden] al cambiar de obra,
     pero display:inline-flex anula el display:none nativo de [hidden]. Esta regla lo
     restituye para que el enlace desaparezca en proyectos sin publicar. */
  .twg-plate .pm .go[hidden] {
    display: none;
  }

  .twg-plate .pm .go:hover {
    opacity: .6;
  }

  /* Indicador "en línea": punto verde con pulso junto a "Ver en línea"
     (solo en proyectos publicados). */
  .twg-plate .pm .go.demo .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5b9c74;
    box-shadow: 0 0 0 0 rgba(91, 156, 116, .5);
    animation: livePulse 2.2s var(--ease) infinite;
  }

  @keyframes livePulse {
    0% {
      box-shadow: 0 0 0 0 rgba(91, 156, 116, .5);
    }
    70% {
      box-shadow: 0 0 0 6px rgba(91, 156, 116, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(91, 156, 116, 0);
    }
  }

  .twg-plate.fade {
    animation: twFade .5s var(--ease);
  }

  @keyframes twFade {
    from {
      opacity: 0;
      transform: translateY(7px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ════════ Acordeon indice (movil/tablet) ════════
     DOM dual: convive con la galeria de escritorio. Oculto por defecto; se
     muestra solo en <=1024px (ver la media query de abajo). */
  .tw-acc {
    display: none;
    border-top: 1px solid var(--line2);
  }

  .twa-item {
    border-bottom: 1px solid var(--line2);
  }

  .twa-head {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 13px;
    align-items: center;
    width: 100%;
    appearance: none;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    color: inherit;
    font-family: inherit;
    padding: 16px 0;
  }

  .twa-no {
    font-family: var(--serif);
    font-size: 20px;
    line-height: 1;
    color: var(--faint);
    transition: color .3s;
  }

  .twa-item.open .twa-no {
    color: var(--teal);
  }

  .twa-tx {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .twa-tt {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 17px;
    line-height: 1.12;
    letter-spacing: -.01em;
  }

  .twa-tg {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .twa-yr {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--faint);
    white-space: nowrap;
  }

  .twa-chev {
    width: 16px;
    height: 16px;
    color: var(--soft);
    transition: transform .35s var(--ease), color .3s;
  }

  .twa-item.open .twa-chev {
    transform: rotate(180deg);
    color: var(--teal);
  }

  /* Panel plegable: anima la altura con grid-template-rows 0fr -> 1fr. */
  .twa-panel {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows .4s var(--ease);
  }

  .twa-item.open .twa-panel {
    grid-template-rows: 1fr;
    padding-bottom: 18px;
  }

  .twa-panel > * {
    min-height: 0; /* permite que el contenido colapse a 0 al cerrar */
  }

  .twa-frame {
    position: relative;
    aspect-ratio: 3 / 2;
    border: 1px solid var(--marco);
    overflow: hidden;
    background: var(--wall);
    box-shadow: 0 14px 34px rgba(0, 0, 0, .13);
    margin-bottom: 13px;
  }

  .twa-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .twa-frame.empty {
    background: repeating-linear-gradient(
      135deg,
      transparent 0 9px,
      color-mix(in srgb, var(--ink) 5%, transparent) 9px 10px
    );
  }

  .twa-frame.empty img {
    display: none;
  }

  .twa-desc {
    font-size: 14px;
    color: var(--soft);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .twa-meta {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 13px;
  }

  .twa-meta .st {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink);
  }

  .twa-meta .go {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--teal);
    border-bottom: 1px solid var(--teal);
    padding-bottom: 2px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: opacity .2s;
  }

  .twa-meta .go:hover {
    opacity: .6;
  }

  .twa-meta .go.demo .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5b9c74;
    box-shadow: 0 0 0 0 rgba(91, 156, 116, .5);
    animation: livePulse 2.2s var(--ease) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .twg-frame .ph {
      transition: opacity .3s;
    }
    .twg-frame .ph.on {
      transform: none;
    }
  }

  @media (max-width: 1024px) {
    /* En flujo movil/tablet la escena mide su contenido y se cambia la galeria
       maestro-detalle por el acordeon indice. */
    .scene.scene-trabajo {
      min-height: 0;
    }

    .tw-galeria {
      display: none;
    }

    .tw-acc {
      display: block;
    }
  }

  /* Tablet (700-1024px): el panel abierto reparte imagen | texto en dos columnas. */
  @media (min-width: 700px) and (max-width: 1024px) {
    .twa-inner {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 24px;
      align-items: start;
    }

    .twa-frame {
      margin-bottom: 0;
    }
  }
</style>
