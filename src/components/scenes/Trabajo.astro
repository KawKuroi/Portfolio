---
/*
  Escena 2 — I · El trabajo. Disposicion fija: Galeria (la unica). Botones a la izquierda y
  escenario a la derecha; la seleccion es SOLO por clic y empieza en el proyecto 0. El render
  se genera en build desde PROYECTOS; un script minimo cambia la obra activa y la placa.
  Datos en src/data/proyectos.ts. PRD 7.2.
*/
import { PROYECTOS } from '../../data/proyectos';

const inicial = PROYECTOS[0];
const numero = (i: number): string => String(i + 1).padStart(2, '0');
---

<section class="scene scene-trabajo" data-slate="El trabajo" data-screen-label="El trabajo">
  <div class="wrap">
    <header class="sh">
      <span class="acto">I</span>
      <h2>El <em>trabajo</em></h2>
      <span class="conteo">{PROYECTOS.length} proyectos</span>
    </header>

    <div id="twGaleria" class="tw-galeria">
      <div class="twg-list">
        {
          PROYECTOS.map((proyecto, i) => (
            <button
              class:list={['twg-item', { on: i === 0 }]}
              type="button"
              data-i={i}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="twg-num">{numero(i)}</span>
              <span class="twg-info">
                <span class="twg-t">{proyecto.titulo}</span>
                <span class="twg-tags">{proyecto.tags}</span>
              </span>
              <span class="twg-anio">{proyecto.anio}</span>
            </button>
          ))
        }
        <p class="twg-pista">// clic en una obra para verla en grande</p>
      </div>

      <div class="twg-stage">
        <div class="twg-frame">
          {
            PROYECTOS.map((proyecto, i) => (
              <div class:list={['ph', { on: i === 0 }]} data-i={i}>
                <img
                  src={proyecto.img}
                  alt={`Captura de ${proyecto.titulo}`}
                  loading="lazy"
                  onerror="this.closest('.ph').classList.add('empty')"
                />
                <span class="twg-cap" aria-hidden="true">
                  <svg class="ic"><use href="#ic-portrait" /></svg>
                  captura
                </span>
              </div>
            ))
          }
        </div>

        <div class="twg-plate">
          <p class="twg-sala">En sala · obra <span data-plate-num>{numero(0)}</span></p>
          <h3 data-plate-titulo>{inicial.titulo}</h3>
          <p class="twg-desc" data-plate-desc>{inicial.descripcion}</p>
          <p class="twg-meta">
            <span data-plate-anio>{inicial.anio}</span> ·
            <span data-plate-estado>{inicial.estado}</span> ·
            <a data-plate-repo href={inicial.repo} target="_blank" rel="noopener">Repo</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { PROYECTOS } from '../../data/proyectos';

  const galeria = document.getElementById('twGaleria');
  if (galeria) {
    const items = Array.from(galeria.querySelectorAll<HTMLButtonElement>('.twg-item'));
    const slides = Array.from(galeria.querySelectorAll<HTMLElement>('.ph'));
    const num = galeria.querySelector('[data-plate-num]');
    const titulo = galeria.querySelector('[data-plate-titulo]');
    const desc = galeria.querySelector('[data-plate-desc]');
    const anio = galeria.querySelector('[data-plate-anio]');
    const estado = galeria.querySelector('[data-plate-estado]');
    const repo = galeria.querySelector<HTMLAnchorElement>('[data-plate-repo]');

    // Seleccion fija por clic: marca el boton/obra activos y vuelca la placa.
    const seleccionar = (i: number): void => {
      const proyecto = PROYECTOS[i];
      if (!proyecto) return;
      items.forEach((boton, j) => {
        const activo = j === i;
        boton.classList.toggle('on', activo);
        boton.setAttribute('aria-pressed', String(activo));
      });
      slides.forEach((slide, j) => slide.classList.toggle('on', j === i));
      if (num) num.textContent = String(i + 1).padStart(2, '0');
      if (titulo) titulo.textContent = proyecto.titulo;
      if (desc) desc.textContent = proyecto.descripcion;
      if (anio) anio.textContent = proyecto.anio;
      if (estado) estado.textContent = proyecto.estado;
      if (repo) repo.href = proyecto.repo;
    };

    items.forEach((boton, i) => boton.addEventListener('click', () => seleccionar(i)));
  }
</script>

<style>
  /* La escena crece con su contenido (PRD 7.2). */
  .scene.scene-trabajo {
    height: auto;
    min-height: 100vh;
    justify-content: flex-start;
  }

  .tw-galeria {
    display: grid;
    grid-template-columns: .9fr 1.1fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: start;
  }

  .twg-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .twg-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 14px 16px;
    text-align: left;
    background: none;
    border: 0;
    border-left: 2px solid transparent;
    color: var(--ink);
    cursor: pointer;
    transition: background .25s var(--ease), border-color .25s var(--ease);
  }

  .twg-item:hover {
    background: var(--wall);
  }

  .twg-item.on {
    background: var(--wall);
    border-left-color: var(--teal);
  }

  .twg-num {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .1em;
    color: var(--faint);
  }

  .twg-item.on .twg-num {
    color: var(--teal);
  }

  .twg-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .twg-t {
    font-size: clamp(15px, 1.9vw, 18px);
    line-height: 1.2;
  }

  .twg-tags {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .04em;
    color: var(--soft);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .twg-anio {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .06em;
    color: var(--faint);
  }

  .twg-pista {
    margin: 14px 0 0;
    padding-left: 16px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .04em;
    color: var(--faint);
  }

  /* Escenario: marco 3/2 con obras superpuestas (solo la activa visible). */
  .twg-frame {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--wall);
    border: 1px solid var(--ink);
    box-shadow: 0 24px 60px -30px rgba(0, 0, 0, .5);
  }

  .ph {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(1.03);
    pointer-events: none;
    transition: opacity .5s var(--ease), transform .5s var(--ease);
  }

  .ph.on {
    opacity: 1;
    transform: none;
  }

  .ph img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Placeholder rayado "captura" si la imagen del proyecto no carga. */
  .twg-cap {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--faint);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .2em;
    text-transform: uppercase;
  }

  .twg-cap .ic {
    font-size: 38px;
  }

  .ph.empty img {
    display: none;
  }

  .ph.empty {
    background-image: repeating-linear-gradient(
      45deg,
      var(--line2) 0,
      var(--line2) 10px,
      transparent 10px,
      transparent 20px
    );
  }

  .ph.empty .twg-cap {
    display: flex;
  }

  /* Placa de la obra en sala. */
  .twg-plate {
    margin-top: 18px;
  }

  .twg-sala {
    margin: 0 0 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--teal);
  }

  .twg-plate h3 {
    margin: 0 0 8px;
    font-style: italic;
    font-size: clamp(20px, 2.6vw, 28px);
    color: var(--ink);
  }

  .twg-desc {
    margin: 0 0 12px;
    font-size: clamp(14px, 1.6vw, 16px);
    line-height: 1.5;
    color: var(--soft);
  }

  .twg-meta {
    margin: 0;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .06em;
    color: var(--faint);
  }

  .twg-meta a {
    color: var(--teal);
    text-decoration: none;
  }

  .twg-meta a:hover {
    text-decoration: underline;
  }

  .twg-item:focus-visible,
  .twg-meta a:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 2px;
  }

  @media (max-width: 820px) {
    .tw-galeria {
      grid-template-columns: 1fr;
    }
  }
</style>
