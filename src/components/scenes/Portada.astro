---
/*
  Escena 1 — Portada. Grid texto | retrato (1 col en <=820px). Copy y estilado 1:1 con el
  diseno original. El retrato degrada con onerror a un placeholder (.ept) sin romper la maqueta.
*/
---

<section class="scene title" data-slate="Portada" data-screen-label="Portada">
  <div class="wrap">
    <div class="title-grid">
      <div class="title-main">
        <div class="kick">Ingeniería de Sistemas</div>
        <h1>Kevin Axel<br /><em>Herazo Rolón</em></h1>
        <div class="role">Backend · Datos · Inteligencia Artificial — Bogotá</div>
        <div class="acts">
          <span><svg class="ic" aria-hidden="true"><use href="#ic-server" /></svg><b>I</b> — El trabajo</span>
          <span><svg class="ic" aria-hidden="true"><use href="#ic-code" /></svg><b>II</b> — El equipo</span>
          <span><svg class="ic" aria-hidden="true"><use href="#ic-film" /></svg><b>III</b> — Conóceme</span>
        </div>
      </div>

      <figure class="portrait">
        <img
          src="/assets/me/retrato.webp"
          alt="Kevin Axel Herazo Rolón"
          fetchpriority="high"
          onerror="this.closest('.portrait').classList.add('empty')"
        />
        <span class="ept"><svg class="ic"><use href="#ic-portrait" /></svg><span>retrato</span></span>
        <figcaption>Kevin A. Herazo R. · autorretrato</figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .title-grid {
    display: grid;
    grid-template-columns: 1fr minmax(0, clamp(230px, 27vw, 344px));
    gap: clamp(28px, 5vw, 76px);
    align-items: center;
  }

  .kick {
    font-family: var(--mono);
    font-size: clamp(11px, 1.5vw, 13px);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 24px;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 7.2vw, 104px);
    line-height: .96;
    letter-spacing: -.02em;
    white-space: nowrap;
  }

  h1 em {
    font-style: italic;
    color: var(--teal);
  }

  .role {
    font-family: var(--mono);
    font-size: clamp(11px, 1.5vw, 15px);
    letter-spacing: .13em;
    text-transform: uppercase;
    color: var(--soft);
    margin-top: 26px;
  }

  .acts {
    display: flex;
    gap: 10px 22px;
    flex-wrap: wrap;
    margin-top: 30px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .acts span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .acts .ic {
    width: 13px;
    height: 13px;
    color: var(--teal);
  }

  .acts b {
    color: var(--ink);
    font-weight: 400;
  }

  /* Retrato 4/5 con marco; el placeholder (.ept) aparece si la imagen no carga (.empty). */
  .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--ink);
    background: var(--wall);
    overflow: hidden;
    box-shadow: 0 18px 44px rgba(0, 0, 0, .13);
  }

  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .portrait figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 11px 13px;
    background: linear-gradient(0deg, color-mix(in srgb, var(--ink) 86%, transparent), transparent);
    color: var(--paper);
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .portrait.empty img {
    display: none;
  }

  .portrait.empty .ept {
    display: flex;
  }

  .ept {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 11px;
    color: var(--faint);
  }

  .ept .ic {
    width: 34px;
    height: 34px;
    stroke-width: 1.2;
  }

  .ept span {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .title-grid {
      grid-template-columns: 1fr;
    }

    .portrait {
      max-width: 240px;
      margin-top: 10px;
    }
  }
</style>
