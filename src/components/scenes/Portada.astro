---
/*
  Escena 1 — Portada. Grid texto | retrato (1 col en <=820px). Copy y estilado 1:1 con el
  diseno original. El retrato degrada con onerror a un placeholder (.ept) sin romper la maqueta.
*/
---

<section class="scene title" data-slate="Portada" data-screen-label="Portada">
  <div class="wrap">
    <div class="title-grid">
      <div class="title-main">
        <div class="kick">Ingeniería de Sistemas</div>
        <h1>Kevin Axel<br /><em>Herazo Rolón</em></h1>
        <div class="role">Datos · Inteligencia Artificial · Automatizaciones — Bogotá</div>
        <div class="acts">
          <span><svg class="ic" aria-hidden="true"><use href="#ic-server" /></svg><b>I</b> — El trabajo</span>
          <span><svg class="ic" aria-hidden="true"><use href="#ic-code" /></svg><b>II</b> — El equipo</span>
          <span><svg class="ic" aria-hidden="true"><use href="#ic-film" /></svg><b>III</b> — Conóceme</span>
        </div>
      </div>

      <figure class="portrait">
        <img
          src="/assets/me/retrato.webp"
          alt="Kevin Axel Herazo Rolón"
          fetchpriority="high"
          onerror="this.closest('.portrait').classList.add('empty')"
        />
        <span class="ept"><svg class="ic"><use href="#ic-portrait" /></svg><span>retrato</span></span>
      </figure>
    </div>
  </div>
</section>

<style>
  .title-grid {
    display: grid;
    grid-template-columns: 1fr minmax(0, clamp(250px, 32vw, 416px));
    gap: clamp(28px, 5vw, 68px);
    align-items: center;
  }

  .kick {
    font-family: var(--mono);
    font-size: clamp(11px, 1.5vw, 13px);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 24px;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 7.2vw, 104px);
    line-height: .96;
    letter-spacing: -.02em;
    white-space: nowrap;
  }

  h1 em {
    font-style: italic;
    color: var(--teal);
  }

  .role {
    font-family: var(--mono);
    /* En escritorio el rol va en una sola linea y se dimensiona en proporcion
       al H1 (~0.9vw) para no superar el ancho del nombre. Movil/tablet recupera
       el tamano original mas abajo. */
    font-size: clamp(9px, 0.9vw, 13px);
    letter-spacing: .13em;
    text-transform: uppercase;
    color: var(--soft);
    margin-top: 26px;
    white-space: nowrap;
  }

  .acts {
    display: flex;
    gap: 10px 22px;
    flex-wrap: wrap;
    margin-top: 30px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .acts span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .acts .ic {
    width: 13px;
    height: 13px;
    color: var(--teal);
  }

  .acts b {
    color: var(--ink);
    font-weight: 400;
  }

  /* Retrato 4/5 con marco; el placeholder (.ept) aparece si la imagen no carga (.empty). */
  .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border: 1px solid var(--ink);
    background: var(--wall);
    overflow: hidden;
    box-shadow: 0 18px 44px rgba(0, 0, 0, .13);
  }

  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .portrait.empty img {
    display: none;
  }

  .portrait.empty .ept {
    display: flex;
  }

  .ept {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 11px;
    color: var(--faint);
  }

  .ept .ic {
    width: 34px;
    height: 34px;
    stroke-width: 1.2;
  }

  .ept span {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  /* ── Movil/tablet (<=1024px): los actos pasan de fila en linea a un indice
     vertical (lista con divisores) y el H1 puede envolver, como la referencia.
     El escritorio (>=1025px) conserva la fila en linea en mayusculas. ── */
  @media (max-width: 1024px) {
    h1 {
      white-space: normal;
      font-size: clamp(44px, 8vw, 76px);
    }

    /* En movil/tablet el rol recupera su tamano original y puede envolver para
       no desbordar en pantallas estrechas; solo en escritorio (>=1025px) se
       fuerza a una sola linea reducida al ancho del nombre. */
    .role {
      font-size: clamp(11px, 1.5vw, 15px);
      white-space: normal;
    }

    .acts {
      flex-direction: column;
      gap: 0;
      margin-top: 24px;
      border-top: 1px solid var(--line2);
      font-size: 13px;
      letter-spacing: normal;
      text-transform: none;
      color: var(--soft);
    }

    .acts span {
      display: flex;
      width: 100%;
      gap: 11px;
      padding: 12px 0;
      border-bottom: 1px solid var(--line2);
    }

    .acts .ic {
      width: 16px;
      height: 16px;
    }

    .acts b {
      font-weight: 700;
      font-size: 11px;
      letter-spacing: .1em;
    }
  }

  /* Telefono (<700px): una columna; el retrato baja bajo el texto. */
  @media (max-width: 699px) {
    .title-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: clamp(40px, 12vw, 62px);
    }

    .portrait {
      /* Ancho explicito (no por estiramiento del grid) para poder centrar con
         margin auto sin que el marco colapse; antes quedaba pegado a la izquierda. */
      width: min(300px, 100%);
      margin: 14px auto 0;
    }
  }
</style>
