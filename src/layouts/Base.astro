---
/*
  Layout base del portafolio. Define el documento, carga la tipografia fija (Libre Baskerville,
  preset Clasica), resuelve el tema e idioma antes del primer pintado (ajustes variables: tema
  claro Museo / oscuro Noche; idioma es/en) y monta el sprite de iconos y el carrete con snap
  vertical. Estructura rigida: disposicion Galeria, acento aguamarino y tipografia Clasica fijos.
*/
import '../styles/tokens.css';
import '../styles/global.css';
import IconSprite from '../components/IconSprite.astro';
import { obtenerIdioma, obtenerTextos } from '../i18n/ui';

interface Props {
  titulo?: string;
  descripcion?: string;
  /** Ruta o URL de la imagen social (OG/Twitter). Por defecto la tarjeta del sitio. */
  imagen?: string;
  /** Ruta canónica de la página (relativa a la raíz). */
  canonical?: string;
}

// Idioma de la pagina (es en `/`, en en `/en/`) y sus textos.
const idioma = obtenerIdioma(Astro.currentLocale);
const t = obtenerTextos(idioma);

// URL pública del sitio (Vercel). Base para canonical, og:url y las URLs absolutas
// que exigen Open Graph y los datos estructurados.
const SITIO = 'https://portfolio-topaz-nu-46.vercel.app';

// Rutas de cada idioma (sitio bilingue, ES por defecto sin prefijo).
const RUTA_ES = '/';
const RUTA_EN = '/en/';

const {
  titulo = t.htmlTitle,
  descripcion = t.metaDescription,
  imagen = '/og-image-v2.png',
  canonical = idioma === 'en' ? RUTA_EN : RUTA_ES,
} = Astro.props;

const urlCanonica = new URL(canonical, SITIO).href;
const urlImagen = new URL(imagen, SITIO).href;
const nombreSitio = t.htmlTitle;
const urlEs = new URL(RUTA_ES, SITIO).href;
const urlEn = new URL(RUTA_EN, SITIO).href;

// Datos estructurados (JSON-LD): identidad (Person) + sitio (WebSite) enlazados, para
// que los buscadores entiendan de quién es el portafolio y habiliten resultados ricos.
const datosEstructurados = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${SITIO}/#kevin`,
      name: 'Kevin Axel Herazo Rolón',
      url: `${SITIO}/`,
      image: urlImagen,
      jobTitle: t.jobTitle,
      description: descripcion,
      knowsAbout: t.knowsAbout,
      sameAs: [
        'https://github.com/KawKuroi',
        'https://www.linkedin.com/in/kevin-axel-herazo-rol%C3%B3n-15a517266/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITIO}/#website`,
      url: `${SITIO}/`,
      name: titulo,
      description: descripcion,
      inLanguage: idioma,
      publisher: { '@id': `${SITIO}/#kevin` },
    },
  ],
};
---

<!doctype html>
<html lang={idioma}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={urlCanonica} />

    <!-- Alternativas de idioma (es/en) para los buscadores -->
    <link rel="alternate" hreflang="es" href={urlEs} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="x-default" href={urlEs} />

    <!-- Iconos: .ico/.png para buscadores (Google ignora el SVG), SVG para navegadores
         modernos, apple-touch para iOS y manifest para "añadir a inicio" en Android. -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbfaf7" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#16130e" />

    <!-- Open Graph (Facebook, LinkedIn, WhatsApp, iMessage…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={nombreSitio} />
    <meta property="og:locale" content={t.ogLocale} />
    <meta property="og:locale:alternate" content={t.ogLocaleAlt} />
    <meta property="og:url" content={urlCanonica} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:image" content={urlImagen} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={nombreSitio} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={urlImagen} />
    <meta name="twitter:image:alt" content={nombreSitio} />

    <!-- Datos estructurados -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(datosEstructurados)} />

    <!-- Detector de idioma: corre antes del primer pintado. La eleccion manual
         (localStorage 'sala-lang') manda; si no hay, sigue navigator.language. Si el idioma
         deseado difiere del de esta pagina, redirige una sola vez (sitio estatico, sin server).
         Tras redirigir el idioma ya coincide, asi que no hay bucle. -->
    <script is:inline>
      (function () {
        try {
          var guardado = localStorage.getItem('sala-lang');
          var deseado =
            guardado === 'es' || guardado === 'en'
              ? guardado
              : (navigator.language || 'es').toLowerCase().indexOf('en') === 0
                ? 'en'
                : 'es';
          var actual = document.documentElement.lang || 'es';
          if (deseado !== actual) {
            location.replace(deseado === 'en' ? '/en/' : '/');
          }
        } catch (e) {
          /* sin localStorage/navigator: se queda en el idioma servido */
        }
      })();
    </script>

    <!-- Resolutor de tema anti-parpadeo: corre antes del primer pintado -->
    <script is:inline>
      (function () {
        try {
          var guardado = localStorage.getItem('sala-theme');
          var valido = guardado === 'Museo' || guardado === 'Noche';
          var oscuro = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var tema = valido ? guardado : oscuro ? 'Noche' : 'Museo';
          document.documentElement.setAttribute('data-tema', tema);
          // Acento real por defecto: aguamarino.
          document.documentElement.style.setProperty('--clay', '#2aa198');
          document.documentElement.style.setProperty('--teal', '#2aa198');
          window.__salaTheme = tema;
        } catch (e) {
          document.documentElement.setAttribute('data-tema', 'Museo');
        }
      })();
    </script>

    <!-- Tipografia fija (preset Clasica): solo Libre Baskerville. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap"
    />
  </head>
  <body>
    <IconSprite />
    <!-- Chrome global (fijo): plaque, riel, hint. Fuera del carrete. -->
    <slot name="chrome" />
    <main class="reel">
      <slot />
    </main>
  </body>
</html>
